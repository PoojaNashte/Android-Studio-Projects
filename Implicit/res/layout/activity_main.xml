<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <LinearLayout
        android:id="@+id/mainLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center"
        android:padding="20dp">

        <Button
            android:id="@+id/btnDial"
            android:layout_width="250dp"
            android:layout_height="wrap_content"
            android:text="Open Dialer"
            android:layout_margin="10dp"/>

        <Button
            android:id="@+id/btnAmazon"
            android:layout_width="250dp"
            android:layout_height="wrap_content"
            android:text="Open Amazon"
            android:layout_margin="10dp"/>

        <Button
            android:id="@+id/btnMaps"
            android:layout_width="250dp"
            android:layout_height="wrap_content"
            android:text="Open Google Maps"
            android:layout_margin="10dp"/>

        <Button
            android:id="@+id/btnGallery"
            android:layout_width="250dp"
            android:layout_height="wrap_content"
            android:text="Open Gallery"
            android:layout_margin="10dp"/>

        <Button
            android:id="@+id/btnLinkedIn"
            android:layout_width="250dp"
            android:layout_height="wrap_content"
            android:text="Open LinkedIn"
            android:layout_margin="10dp"/>

        <Button
            android:id="@+id/btnYoutube"
            android:layout_width="250dp"
            android:layout_height="wrap_content"
            android:text="Open YouTube"
            android:layout_margin="10dp"/>

        <Button
            android:id="@+id/btnInstagram"
            android:layout_width="250dp"
            android:layout_height="wrap_content"
            android:text="Open Instagram"
            android:layout_margin="10dp"/>

        <Button
            android:id="@+id/btnSnapchat"
            android:layout_width="250dp"
            android:layout_height="wrap_content"
            android:text="Open Snapchat"
            android:layout_margin="10dp"/>

    </LinearLayout>
</ScrollView>