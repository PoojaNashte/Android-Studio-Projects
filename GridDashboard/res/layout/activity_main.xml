<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F5F5">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp"
        android:gravity="center_horizontal">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="List of Experiments"
            android:textSize="22sp"
            android:textStyle="bold"
            android:layout_marginBottom="8dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Pooja Nashte"
            android:textSize="18sp"
            android:layout_marginBottom="4dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Roll No: 18"
            android:textSize="18sp"
            android:layout_marginBottom="24dp"/>

        <GridLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:columnCount="3">

            <LinearLayout
                android:layout_width="110dp"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center"
                android:layout_margin="8dp">

                <Button
                    android:id="@+id/exp1"
                    android:layout_width="100dp"
                    android:layout_height="100dp"
                    android:text="Exp 1"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="LinearLayout"
                    android:textSize="12sp"/>
            </LinearLayout>

            <LinearLayout
                android:layout_width="110dp"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center"
                android:layout_margin="8dp">

                <Button
                    android:id="@+id/exp2"
                    android:layout_width="100dp"
                    android:layout_height="100dp"
                    android:text="Exp 2"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="RelativeLayout"
                    android:textSize="12sp"/>
            </LinearLayout>

            <LinearLayout
                android:layout_width="110dp"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center"
                android:layout_margin="8dp">

                <Button
                    android:id="@+id/exp3"
                    android:layout_width="100dp"
                    android:layout_height="100dp"
                    android:text="Exp 3"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="FrameLayout"
                    android:textSize="12sp"/>
            </LinearLayout>

            <LinearLayout
                android:layout_width="110dp"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center"
                android:layout_margin="8dp">

                <Button
                    android:id="@+id/exp4"
                    android:layout_width="100dp"
                    android:layout_height="100dp"
                    android:text="Exp 4"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="TableLayout"
                    android:textSize="12sp"/>
            </LinearLayout>

            <LinearLayout
                android:layout_width="110dp"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center"
                android:layout_margin="8dp">

                <Button
                    android:id="@+id/exp5"
                    android:layout_width="100dp"
                    android:layout_height="100dp"
                    android:text="Exp 5"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="GridLayout"
                    android:textSize="12sp"/>
            </LinearLayout>

            <LinearLayout
                android:layout_width="110dp"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center"
                android:layout_margin="8dp">

                <Button
                    android:id="@+id/exp6"
                    android:layout_width="100dp"
                    android:layout_height="100dp"
                    android:text="Exp 6"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="ConstraintLayout"
                    android:textSize="12sp"/>
            </LinearLayout>

            <!-- EXP 7 -->
            <LinearLayout
                android:layout_width="110dp"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center"
                android:layout_margin="8dp">

                <Button
                    android:id="@+id/exp7"
                    android:layout_width="100dp"
                    android:layout_height="100dp"
                    android:text="Exp 7"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="AbsoluteLayout"
                    android:textSize="12sp"/>
            </LinearLayout>

            <LinearLayout
                android:layout_width="110dp"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center"
                android:layout_margin="8dp">

                <Button
                    android:id="@+id/exp8"
                    android:layout_width="100dp"
                    android:layout_height="100dp"
                    android:text="Exp 8"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="LoginLayout"
                    android:textSize="12sp"/>
            </LinearLayout>

            <LinearLayout
                android:layout_width="110dp"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center"
                android:layout_margin="8dp">

                <Button
                    android:id="@+id/exp9"
                    android:layout_width="100dp"
                    android:layout_height="100dp"
                    android:text="Exp 9"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="ProfileLayout"
                    android:textSize="12sp"/>
            </LinearLayout>

        </GridLayout>

    </LinearLayout>

</ScrollView>