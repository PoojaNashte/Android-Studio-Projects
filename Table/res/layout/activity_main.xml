<?xml version="1.0" encoding="utf-8"?>
<TableLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="20dp"
    android:stretchColumns="*">

    <!-- Title Row -->
    <TableRow>
        <TextView
            android:layout_span="3"
            android:layout_gravity="center"
            android:text="TableLayout Experiment"
            android:textSize="22sp"
            android:textStyle="bold"
            android:paddingBottom="20dp"/>
    </TableRow>

    <!-- Row 1 -->
    <TableRow>
        <TextView
            android:text="Name"
            android:textStyle="bold"/>
        <TextView
            android:text="Roll No"
            android:textStyle="bold"/>
        <TextView
            android:text="Division"
            android:textStyle="bold"/>
    </TableRow>

    <!-- Row 2 -->
    <TableRow>
        <TextView
            android:text="Pooja"/>
        <TextView
            android:text="18"/>
        <TextView
            android:text="B"/>
    </TableRow>

    <!-- Row 3 -->
    <TableRow>
        <TextView
            android:text="Sarthi"/>
        <TextView
            android:text="23"/>
        <TextView
            android:text="B"/>
    </TableRow>

    <TableRow>
        <TextView
            android:text="Aishwarya"/>
        <TextView
            android:text="21"/>
        <TextView
            android:text="B"/>
    </TableRow>
</TableLayout>